    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@swc/core": "^1.15.21",
    "@swc/helpers": "^0.5.19",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.28",
